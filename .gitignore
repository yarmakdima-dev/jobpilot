# ============================================================
# JobPilot .gitignore
# ============================================================
# Enforces the Data Contract: User Layer files never committed.
# See DATA_CONTRACT.md for the full rule.
# ============================================================

# ---- User Layer: personal data, never commit ----
cv.md
voice_pack.md
story_bank.md
config/profile.yml
companies/
roles/
pipeline.json
decisions.log
inbox_events/
reports/
output/

# ---- Secrets and credentials ----
.env
.env.local
.env.*.local
*.key
*.pem
credentials.json
service-account*.json

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.venv/
venv/
env/

# ---- Node ----
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ---- OS and editor junk ----
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
*~

# ---- Build and cache ----
dist/
build/
*.log
.cache/
